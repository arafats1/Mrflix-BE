{
  "kind": "collectionType",
  "collectionName": "purchases",
  "info": {
    "singularName": "purchase",
    "pluralName": "purchases",
    "displayName": "Purchase",
    "description": "Movie purchase records"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "movie": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "api::movie.movie"
    },
    "buyer": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "amount": {
      "type": "integer",
      "required": true
    },
    "paymentMethod": {
      "type": "enumeration",
      "enum": ["mtn_momo", "airtel_money", "pesapal"],
      "required": true
    },
    "paymentPhone": {
      "type": "string",
      "required": true
    },
    "transactionId": {
      "type": "string"
    },
    "status": {
      "type": "enumeration",
      "enum": ["pending", "completed", "failed"],
      "default": "pending",
      "required": true
    },
    "downloadCount": {
      "type": "integer",
      "default": 0
    },
    "seasonNumber": {
      "type": "integer"
    },
    "pesapalTrackingId": {
      "type": "string"
    }
  }
}
