{
  "kind": "collectionType",
  "collectionName": "referrals",
  "info": {
    "singularName": "referral",
    "pluralName": "referrals",
    "displayName": "Referral",
    "description": "Tracks referral codes, activations, and rewards"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "referrer": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "referred": {
      "type": "relation",
      "relation": "manyToOne",
      "target": "plugin::users-permissions.user"
    },
    "code": {
      "type": "string",
      "required": true
    },
    "status": {
      "type": "enumeration",
      "enum": ["pending", "activated", "rewarded"],
      "default": "pending"
    },
    "rewardMovieCount": {
      "type": "integer",
      "default": 3
    },
    "referrerMoviesRemaining": {
      "type": "integer",
      "default": 0
    },
    "referredMoviesRemaining": {
      "type": "integer",
      "default": 0
    }
  }
}
