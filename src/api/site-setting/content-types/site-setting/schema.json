{
  "kind": "singleType",
  "collectionName": "site_settings",
  "info": {
    "singularName": "site-setting",
    "pluralName": "site-settings",
    "displayName": "Site Setting",
    "description": "Global site configuration including pricing"
  },
  "options": {
    "draftAndPublish": false
  },
  "pluginOptions": {},
  "attributes": {
    "moviePrice": {
      "type": "integer",
      "required": true,
      "default": 2000
    },
    "seriesPrice": {
      "type": "integer",
      "required": true,
      "default": 5000
    },
    "subscriptionPrice": {
      "type": "integer",
      "required": true,
      "default": 20000
    },
    "subscriptionEnabled": {
      "type": "boolean",
      "default": true
    },
    "apkUrl": {
      "type": "string"
    },
    "apkVersion": {
      "type": "string"
    },
    "apkSize": {
      "type": "string"
    },
    "apkUpdatedAt": {
      "type": "datetime"
    },
    "apkDownloadCount": {
      "type": "integer",
      "default": 0
    },
    "mobileApkUrl": {
      "type": "string"
    },
    "mobileApkVersion": {
      "type": "string"
    },
    "mobileApkSize": {
      "type": "string"
    },
    "mobileApkUpdatedAt": {
      "type": "datetime"
    },
    "mobileApkDownloadCount": {
      "type": "integer",
      "default": 0
    },
    "freeTrialCount": {
      "type": "integer",
      "default": 2,
      "required": true
    },
    "pesapalIpnId": {
      "type": "string"
    },
    "freeMovieOfWeekEnabled": {
      "type": "boolean",
      "default": false
    },
    "freeMovieOfWeekId": {
      "type": "string"
    },
    "freeMovieOfWeekExpiresAt": {
      "type": "datetime"
    },
    "referralEnabled": {
      "type": "boolean",
      "default": true
    },
    "referralRewardMovies": {
      "type": "integer",
      "default": 3
    }
  }
}
